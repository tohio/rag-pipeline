# =============================================================
# rag-pipeline — .gitignore
# =============================================================


# -------------------------------------------------------------
# Environment & Secrets — NEVER commit these
# -------------------------------------------------------------
.env
.env.local
.env.*.local


# -------------------------------------------------------------
# Data — documents and vector index
# -------------------------------------------------------------
data/raw/
data/processed/
data/chroma/


# -------------------------------------------------------------
# Python
# -------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python
build/
dist/
*.egg-info/
*.egg
.eggs/


# -------------------------------------------------------------
# Virtual Environments
# -------------------------------------------------------------
venv/
.venv/
env/
.env/
ENV/


# -------------------------------------------------------------
# Testing & Coverage
# -------------------------------------------------------------
.pytest_cache/
.coverage
htmlcov/
coverage.xml
*.log


# -------------------------------------------------------------
# Evaluation Results
# -------------------------------------------------------------
evaluation/results.json
evaluation/results/


# -------------------------------------------------------------
# Jupyter Notebooks — outputs only, keep the notebooks
# -------------------------------------------------------------
notebooks/.ipynb_checkpoints/
*.ipynb_checkpoints


# -------------------------------------------------------------
# IDEs & Editors
# -------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db


# -------------------------------------------------------------
# Docker
# -------------------------------------------------------------
*.dockerignore


# -------------------------------------------------------------
# Misc
# -------------------------------------------------------------
*.log
*.tmp
*.bak
