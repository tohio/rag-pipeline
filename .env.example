# =============================================================
# rag-pipeline — Environment Variables
# =============================================================
# Copy this file to .env and fill in your values.
#   cp .env.example .env
#
# Never commit .env to version control.
# All variables have sensible defaults except API keys.
# =============================================================


# -------------------------------------------------------------
# LLM Configuration
# -------------------------------------------------------------

# LLM provider: openai | anthropic
LLM_PROVIDER=openai

# OpenAI API key (required if LLM_PROVIDER=openai)
OPENAI_API_KEY=your-openai-api-key-here

# OpenAI model (default: gpt-4o)
OPENAI_MODEL=gpt-4o

# Anthropic API key (required if LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Anthropic model (default: claude-3-5-sonnet-20241022)
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# LLM temperature — low for factual Q&A (default: 0.1)
LLM_TEMPERATURE=0.1

# Max tokens in generated response (default: 512)
LLM_MAX_TOKENS=512


# -------------------------------------------------------------
# Embedding Configuration
# -------------------------------------------------------------

# Embedding model (default: text-embedding-3-small)
# Options: text-embedding-3-small | text-embedding-3-large
EMBEDDING_MODEL=text-embedding-3-small


# -------------------------------------------------------------
# Chunking Configuration
# -------------------------------------------------------------

# Number of tokens per chunk (default: 512)
# Smaller = more precise retrieval | Larger = more context per chunk
CHUNK_SIZE=512

# Number of overlapping tokens between chunks (default: 50)
# Must be less than CHUNK_SIZE
CHUNK_OVERLAP=50


# -------------------------------------------------------------
# Vector Store Configuration (Chroma)
# -------------------------------------------------------------

# Directory where Chroma persists the index (default: ./data/chroma)
CHROMA_PERSIST_DIR=./data/chroma

# Chroma collection name (default: meridian_hr)
CHROMA_COLLECTION_NAME=meridian_hr

# Force rebuild the index on next run (default: false)
# Set to true when you update source documents
FORCE_REBUILD=false


# -------------------------------------------------------------
# Retrieval Configuration
# -------------------------------------------------------------

# Number of chunks to retrieve per query (default: 5)
RETRIEVAL_TOP_K=5

# Minimum similarity score to include a result (default: 0.3)
# Lower = more results, potentially noisier
# Higher = fewer results, potentially missing relevant context
SIMILARITY_CUTOFF=0.3


# -------------------------------------------------------------
# Gradio UI Configuration
# -------------------------------------------------------------

# Port for the Gradio demo server (default: 7860)
GRADIO_PORT=7860
